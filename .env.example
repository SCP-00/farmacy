# ══════════════════════════════════════════════════════════
#  FARMACY — Variables de entorno
#  cp .env.example .env  → luego rellena los valores reales
# ══════════════════════════════════════════════════════════

# ── Servidor backend ──────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# ── Base de datos PostgreSQL ──────────────────────────────
DATABASE_URL="postgresql://farmacy_user:farmacy_pass@localhost:5432/farmacy_db"

# ── Redis (caché) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT — Empleados (panel admin) ─────────────────────────
JWT_SECRET=cambia_esto_minimo_32_caracteres_secreto_empleados_01
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=otro_secreto_diferente_minimo_32_caracteres_refresh_02
JWT_REFRESH_EXPIRES_IN=7d

# ── JWT — Clientes (tienda web) ───────────────────────────
JWT_CLIENTE_SECRET=secreto_para_clientes_minimo_32_caracteres_03
JWT_CLIENTE_EXPIRES_IN=30d

# ── OAuth Google (opcional) ───────────────────────────────
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/clientes/auth/google/callback

# ── OAuth Facebook (opcional) ─────────────────────────────
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_CALLBACK_URL=http://localhost:3001/api/v1/clientes/auth/facebook/callback

# ── Email / SMTP ──────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@correo.com
# SMTP_PASS=tu_contraseña_de_aplicacion
EMAIL_FROM=Farmacy <no-reply@farmacy.co>

# ── Cloudinary (imágenes) ─────────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Wompi — Colombia sandbox ──────────────────────────────
# WOMPI_PUBLIC_KEY=pub_stagtest_xxxxx
# WOMPI_PRIVATE_KEY=prv_stagtest_xxxxx
# WOMPI_EVENTS_SECRET=stagtest_events_xxxxx
WOMPI_BASE_URL=https://sandbox.wompi.co/v1

# ── Stripe (opcional) ─────────────────────────────────────
# STRIPE_PUBLIC_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ── MercadoPago (opcional) ────────────────────────────────
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxx
# MERCADOPAGO_PUBLIC_KEY=TEST-xxxxx

# ── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ── Logs ──────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Chatbot — horario de atención humana ─────────────────
HORARIO_INICIO=08:00
HORARIO_FIN=18:00
HORARIO_TIMEZONE=America/Bogota
HORARIO_DIAS=1,2,3,4,5

# ── Info farmacia ─────────────────────────────────────────
FARMACIA_NOMBRE=Farmacy

# ── Variables Vite (frontend) ─────────────────────────────
VITE_API_URL=http://localhost:3001/api/v1
VITE_APP_NAME=Farmacy
